{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<absolute-plugin-root>\\hooks\\user_prompt_submit.py\"",
            "timeout": 20,
            "statusMessage": "Fable Yeon Skill (Codex)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<absolute-plugin-root>\\hooks\\pre_tool_use.py\"",
            "timeout": 20,
            "statusMessage": "Fable Yeon Skill (Codex)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<absolute-plugin-root>\\hooks\\post_tool_use.py\"",
            "timeout": 20,
            "statusMessage": "Fable Yeon Skill (Codex)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<absolute-plugin-root>\\hooks\\stop.py\"",
            "timeout": 20,
            "statusMessage": "Fable Yeon Skill (Codex)"
          }
        ]
      }
    ]
  }
}

